<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.20/owo-ui.xsd">

    <components>
        <flow-layout direction="vertical">
            <sizing>
                <horizontal method="fill">100</horizontal>
                <vertical method="fill">100</vertical>
            </sizing>
            <surface>
                <vanilla-translucent/>
            </surface>
            <padding>
                <top>10</top>
                <bottom>10</bottom>
                <left>15</left>
                <right>15</right>
            </padding>

            <children>
                <flow-layout direction="horizontal">
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="content"/>
                    </sizing>
                    <alignment horizontal="center" vertical="center"/>
                    <children>
                        <label id="title-label">
                            <text translate="true">gui.chunk-destroyer.title</text>
                            <shadow>true</shadow>
                        </label>
                    </children>
                </flow-layout>

                <flow-layout direction="vertical">
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="content"/>
                    </sizing>
                    <alignment horizontal="left" vertical="top"/>
                    <margins>
                        <top>20</top>
                    </margins>
                    <children>
                        <flow-layout direction="horizontal">
                            <sizing>
                                <horizontal method="content"/>
                                <vertical method="content"/>
                            </sizing>
                            <alignment horizontal="left" vertical="center"/>
                            <margins>
                                <bottom>8</bottom>
                            </margins>
                            <children>
                                <label>
                                    <text translate="true">gui.chunk-destroyer.radius</text>
                                    <margins>
                                        <right>8</right>
                                    </margins>
                                </label>
                                <text-box id="radius-input">
                                    <sizing>
                                        <horizontal method="fixed">60</horizontal>
                                    </sizing>
                                </text-box>
                            </children>
                        </flow-layout>

                        <flow-layout direction="horizontal">
                            <sizing>
                                <horizontal method="content"/>
                                <vertical method="content"/>
                            </sizing>
                            <alignment horizontal="left" vertical="center"/>
                            <margins>
                                <bottom>8</bottom>
                            </margins>
                            <children>
                                <label>
                                    <text translate="true">gui.chunk-destroyer.up</text>
                                    <margins>
                                        <right>8</right>
                                    </margins>
                                </label>
                                <text-box id="up-input">
                                    <sizing>
                                        <horizontal method="fixed">60</horizontal>
                                    </sizing>
                                </text-box>
                            </children>
                        </flow-layout>

                        <flow-layout direction="horizontal">
                            <sizing>
                                <horizontal method="content"/>
                                <vertical method="content"/>
                            </sizing>
                            <alignment horizontal="left" vertical="center"/>
                            <children>
                                <label>
                                    <text translate="true">gui.chunk-destroyer.down</text>
                                    <margins>
                                        <right>8</right>
                                    </margins>
                                </label>
                                <text-box id="down-input">
                                    <sizing>
                                        <horizontal method="fixed">60</horizontal>
                                    </sizing>
                                </text-box>
                            </children>
                        </flow-layout>
                    </children>
                </flow-layout>

                <flow-layout direction="vertical">
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="expand">100</vertical>
                    </sizing>
                </flow-layout>

                <flow-layout direction="horizontal">
                    <sizing>
                        <horizontal method="fill">100</horizontal>
                        <vertical method="content"/>
                    </sizing>
                    <alignment horizontal="center" vertical="center"/>
                    <children>
                        <button id="save-button">
                            <text translate="true">gui.chunk-destroyer.save</text>
                            <sizing>
                                <horizontal method="fixed">200</horizontal>
                                <vertical method="fixed">20</vertical>
                            </sizing>
                        </button>
                    </children>
                </flow-layout>
            </children>
        </flow-layout>
    </components>
</owo-ui>