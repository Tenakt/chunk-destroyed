<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo-lib/1.21/owo-ui.xsd">

    <components>
        <flow-layout direction="vertical" alignment="center">

            <panel dark="true" padding="15">
                <children>
                    <flow-layout direction="vertical" gap="10">
                        <children>

                            <label>
                                <text>Настройки /destroy</text>
                                <shadow>true</shadow>
                            </label>

                            <label><text>Радиус удаления:</text></label>
                            <discrete-slider id="radius-slider">
                                <min>1</min>
                                <max>128</max>
                            </discrete-slider>

                            <label><text>Высота вверх:</text></label>
                            <discrete-slider id="height-up-slider">
                                <min>0</min>
                                <max>384</max>
                            </discrete-slider>

                            <label><text>Высота вниз:</text></label>
                            <discrete-slider id="height-down-slider">
                                <min>0</min>
                                <max>384</max>
                            </discrete-slider>

                            <button id="save-button">
                                <text>Сохранить</text>
                            </button>

                        </children>
                    </flow-layout>
                </children>
            </panel>

        </flow-layout>
    </components>

</owo-ui>